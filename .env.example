# Postgres connection (Neon free tier works great)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Single-admin login
ADMIN_EMAIL="ade@ayendecx.com"
# Generate a hash with:  npm run hash -- "your-password"
ADMIN_PASSWORD_HASH=""
# For quick local dev only, you may set a plaintext password instead of a hash:
# ADMIN_PASSWORD="changeme"

# Secret used to sign the session cookie (any long random string)
SESSION_SECRET="please-change-this-to-a-long-random-string"

# Base URL (used for share links). Local dev default:
APP_BASE_URL="http://localhost:3000"

# Email (Resend) — used to email quote share links to clients.
# Until these are set, emailing falls back gracefully (the share link still works).
# Create a key at https://resend.com and verify the ayendecx.com sending domain.
RESEND_API_KEY=""
# From address (must be on a domain verified in Resend):
QUOTE_FROM_EMAIL="Ayende Consulting Inc. <quotes@ayendecx.com>"
